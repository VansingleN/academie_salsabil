# Clé secrète Stripe de test. Ne jamais placer une vraie valeur dans Git.
STRIPE_SECRET_KEY=sk_test_a_remplacer

# Fourni par Stripe après création de l'endpoint /api/stripe-webhook.
STRIPE_WEBHOOK_SECRET=whsec_a_remplacer

# Laisser à false tant que le portail n'est pas configuré dans Stripe Dashboard.
STRIPE_PORTAL_ENABLED=false

# L'envoi réel reste coupé tant que le domaine et Brevo ne sont pas configurés.
TRANSACTIONAL_EMAIL_MODE=disabled

# Valeurs futures à renseigner uniquement lors de l'activation de Brevo.
TRANSACTIONAL_EMAIL_PROVIDER=brevo
TRANSACTIONAL_EMAIL_DELIVERY_MODE=test
TRANSACTIONAL_EMAIL_INTERNAL_RECIPIENT=
TRANSACTIONAL_EMAIL_SENDER_EMAIL=
TRANSACTIONAL_EMAIL_SENDER_NAME=Académie Salsabil
TRANSACTIONAL_EMAIL_REPLY_TO_EMAIL=
TRANSACTIONAL_EMAIL_REPLY_TO_NAME=Académie Salsabil

# En mode test, seuls ces destinataires séparés par des virgules sont acceptés.
TRANSACTIONAL_EMAIL_TEST_RECIPIENTS=
TRANSACTIONAL_EMAIL_TIMEOUT_MS=10000

# Secret Brevo : conserver la valeur uniquement dans .env ou dans Netlify.
BREVO_API_KEY=
