# Clé secrète Stripe de test. Ne jamais placer une vraie valeur dans Git.
STRIPE_SECRET_KEY=sk_test_a_remplacer

# Fourni par Stripe après création de l'endpoint /api/stripe-webhook.
STRIPE_WEBHOOK_SECRET=whsec_a_remplacer

# Laisser à false tant que le portail n'est pas configuré dans Stripe Dashboard.
STRIPE_PORTAL_ENABLED=false
